# FinAgent-SG — Docker Compose Environment Variables
#
# Copy this file to docker-compose.env and fill in your values.
# Run: cp docker-compose.env.example docker-compose.env
#
# NEVER commit docker-compose.env to git — it contains real secrets.
# docker-compose.env is already listed in .gitignore.
#
# Usage: docker compose --env-file docker-compose.env up -d

# ── PostgreSQL (Langfuse's internal DB) ───────────────────────────────────────
# These credentials are used only inside Docker — they do not affect Supabase.
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=your-postgres-password-here
LANGFUSE_DB_NAME=langfuse

# ── Langfuse Server Auth ──────────────────────────────────────────────────────
# NEXTAUTH_SECRET: generate with: openssl rand -base64 32
# SALT: generate with: openssl rand -base64 32 (must be different from NEXTAUTH_SECRET)
LANGFUSE_NEXTAUTH_SECRET=your-nextauth-secret-here
LANGFUSE_SALT=your-salt-here

# ── Langfuse Auto-Init (creates default org, project, user on first run) ───────
# These let you log in at http://localhost:3001 immediately without manual setup.
LANGFUSE_INIT_ORG_NAME=FinAgent-SG
LANGFUSE_INIT_PROJECT_NAME=finagent-sg
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_PASSWORD=your-admin-password-here
LANGFUSE_INIT_USER_NAME=Admin

# ── Langfuse Project Keys (copy from the Langfuse dashboard after first run) ──
# Log in at http://localhost:3001, go to Settings → API Keys, copy Public + Secret key.
# Then paste them here AND into your .env.local (as LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY).
# These can also be pre-set here to match LANGFUSE_INIT_* above if you know them in advance.
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf-pk-your-public-key-here
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf-sk-your-secret-key-here
