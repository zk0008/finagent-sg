# FinAgent-SG — ML Pipeline Environment Variables
#
# Copy this file to ml/.env and fill in your values before running.
# Run: cp .env.example .env
#
# NEVER commit ml/.env to git — it contains real secrets.
# ml/.env is already listed in .gitignore.

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required. Used for embeddings (text-embedding-3-small) and answer generation (gpt-4.1-mini).
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Host and port where ChromaDB is running locally (via Docker).
# Default: localhost:8000 — matches docker-compose.yml config.
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Collection name ───────────────────────────────────────────────────────────
# Must match the collection name used in the Next.js ingestion pipeline (lib/chromaClient.ts).
CHROMA_COLLECTION=sfrs_knowledge
