# OpenAI API key — used by Vercel AI SDK for all LLM calls
OPENAI_API_KEY=

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Supabase connection — fill in after creating project at supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ChromaDB — runs locally on default port
CHROMA_URL=http://localhost:8000

# Langfuse observability — self-hosted via Docker Compose (Phase 5)
# Start Langfuse: docker compose --env-file docker-compose.env up -d
# Dashboard:      http://localhost:3001 (log in, go to Settings → API Keys)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
